# Optional AI wording feedback for role calls. Authored feedback works without it.
# The account also needs active API credits. Get a key at https://platform.claude.com.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Recommended cloud role-call provider. Keep this key server-side only.
# Flash-Lite supplies structured coaching and open-ended persona turns.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite
# Audio-only speech translation assist via the Gemini Live API.
GEMINI_TRANSLATE_MODEL=gemini-3.5-live-translate-preview

# Optional private, on-device AI feedback. Install Ollama and pull this model.
# When both providers are available, local feedback is preferred by default.
OLLAMA_MODEL=llama3.2
# Set to gemini or anthropic to prefer cloud feedback while retaining fallback.
AI_FEEDBACK_PROVIDER=gemini
